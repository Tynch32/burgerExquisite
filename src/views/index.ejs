<!DOCTYPE html>
<html>
  <%-include('partials/head') %>
  <body>
    <%-include('partials/header',{title}) %>
    <main>
        <div class="d-flex justify-content-center">
          <div class="card col-lg-11 col-12 main_container">
            <div class="navbar_container">
              <div>
                <form class="d-flex navbar_searchbar" role="search">
                  <!-- Input de búsqueda -->
                  <% if (locals.userLogin) { %>
                    <% if (locals.userLogin.role===1) { %>
                      <li id="header_button_3"><a href="/admin/registeredUsers">ADMIN <i class="fa-solid fa-screwdriver-wrench"></i></a></li>
                    <% } %>
                    <% if (locals.userLogin.role===0) {%>
                      <li id="header_button_3"><a href="/admin/editTokenUser">USER <i class="fa-solid fa-screwdriver-wrench"></i></a></li>
                      <li id="header_button_3"><a href="/admin/registeredUsers">ADMIN <i class="fa-solid fa-screwdriver-wrench"></i></a></li>
                    <% } %>    
                  <% } %>  
                  <li id="header_button_5"><a href="/users/logout">salir <i class="fa-solid fa-door-open"></i></a></li>
                  <input id="searchInput" class="form-control" type="search"
                        placeholder="&#128269; Buscar productos por nombre" aria-label="Search">
                  <div>
                    <button class="btn btn-primary buttonModificar" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasScrolling" aria-controls="offcanvasScrolling"><i class="fa-solid fa-bars"></i></button>
                    <div class="offcanvas offcanvas-start" data-bs-scroll="true" data-bs-backdrop="false" tabindex="-1" id="offcanvasScrolling" aria-labelledby="offcanvasScrollingLabel">
                      <div class="offcanvas-header">
                        <h5 class="offcanvas-title" id="offcanvasScrollingLabel">Burguer Exquisite</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                      </div>
                      <div class="offcanvas-body">
                        <nav class="navbar bg-body-tertiary">
                          <div class="container-fluid">
                            <a class="navbar-brand registerLogin" href="/users/login">Ya tengo Cuenta!</a>
                          </div>
                        </nav>
                        <br>
                        <nav class="navbar bg-body-tertiary">
                          <div class="container-fluid">
                            <a class="navbar-brand registerLogin" href="/users/register">Registrarme</a>
                          </div>
                        </nav>
                      </div>
                    </div>
                  </div>
                  <div>

                  </div>
                </form>
              </div>
              <div class="categories_container">
                <% categories.forEach((category,index)=> { %>
                  <div class="category" data-id="<%= category.name %>">
                    <%-include('partials/category', { category,index }) %>
                  </div>
                  <% }); %>
              </div>
            </div>
            <div id="content">
              <% categories.forEach(category=> { %>
                <section id="<%= category.name %>">
                  <%-include('partials/section',{category,products}) %>
                </section>
                <% }); %>
            </div>
          </div>
        </div>
      </main>
    <%-include('partials/footer') %>
<script>
  document.getElementById('searchInput').addEventListener('input', function (e) {
    const searchQuery = e.target.value.toLowerCase();

    // Ajuste para el desplazamiento
    const offset = 207; // Cambia este valor al tamaño de tu barra fija

    // Si el input está vacío, subimos hasta arriba
    if (searchQuery === '') {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
      return; // Salimos de la función
    }

    // Buscamos todas las secciones dentro del contenedor de categorías
    const sections = document.querySelectorAll('#content section');

    // Buscamos todos los productos
    const products = document.querySelectorAll('.product');

    let foundMatch = false; // Bandera para saber si encontramos algo

    // Primero buscamos por categorías
    sections.forEach(section => {
      const categoryName = section.id.toLowerCase();
      if (categoryName.includes(searchQuery)) {
        const sectionPosition = section.getBoundingClientRect().top + window.pageYOffset;
        window.scrollTo({
          top: sectionPosition - offset,
          behavior: 'smooth'
        });
        foundMatch = true;
      }
    });

    // Si no encontramos coincidencias por categoría, buscamos en los productos
    if (!foundMatch) {
      for (const product of products) {
        const productName = product.getAttribute('data-product-name').toLowerCase();
        if (productName.includes(searchQuery)) {
          const productPosition = product.getBoundingClientRect().top + window.pageYOffset;
          window.scrollTo({
            top: productPosition - offset,
            behavior: 'smooth'
          });
          break; // Detiene el bucle en el primer resultado encontrado
        }
      }
    }
  });
</script>
        <script>
          // Seleccionamos todos los elementos de categoría dentro del contenedor
          const categories = document.querySelectorAll('.categories_container .category');

          // Definimos el offset (ajuste de desplazamiento para evitar que se tape la sección)
          const offset = 207; // Ajusta este valor según la altura de tu contenedor

          // Recorremos cada categoría y le añadimos el evento click
          categories.forEach(category => {
            category.addEventListener('click', function () {
              // Obtenemos el id de la categoría desde el atributo data-id
              const categoryId = category.getAttribute('data-id');

              // Buscamos la sección correspondiente por id
              const targetSection = document.getElementById(categoryId);

              // Si existe la sección, desplazamos la página hacia esa sección
              if (targetSection) {
                const sectionPosition = targetSection.getBoundingClientRect().top + window.pageYOffset;

                // Desplazamos la página manualmente ajustando con el offset
                window.scrollTo({
                  top: sectionPosition - offset,
                  behavior: 'smooth'
                });
              }
            });
          });
        </script>
  </body>

</html>
