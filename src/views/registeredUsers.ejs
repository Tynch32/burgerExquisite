<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', {title: "Panel Admin" }) %>
    <body class="">
        <%- include('partials/header') %>
            <main id="home_main" class="container">
                <div class="row">
                    <div class="col-12 col-lg-10 mx-auto mt-5">
                        <div class="card shadow">
                            <div class="card-body">
                                <ul class="nav nav-tabs" id="myTab" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link active" id="users-tab" data-bs-toggle="tab"
                                            data-bs-target="#users" type="button" role="tab" aria-controls="users"
                                            aria-selected="false">Usuarios</button>
                                    </li>
                                </ul>
                                <div class="tab-content" id="myTabContent">
                                    <div class="tab-pane fade show active" id="users" role="tabpanel"
                                        aria-labelledby="users-tab">
                                        <%- include('partials/tableUsers',{users, moment}) %>
                                    </div>
                                    <div class="tab-pane fade" id="contact" role="tabpanel"
                                        aria-labelledby="contact-tab">
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </main>
            <%- include('partials/footer') %>
            <%- include('partials/scripts') %>
    </body>

</html>